# === CogniLeapAI MVP Environment Configuration ===
# Copy this file to .env.local and fill in your actual values

# === AI Provider Configuration ===
# Kie.ai API key (preferred — budget-friendly Gemini access)
# Get your API key from: https://kie.ai
KIE_API_KEY=your_kie_api_key_here
# Default model for Kie.ai (optional — defaults to gemini-3-flash)
KIE_DEFAULT_MODEL=gemini-3-flash

# Google Gemini AI key (legacy fallback — only needed if not using Kie)
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_GENERATIVE_AI_API_KEY=
GOOGLE_AI_API_KEY=

# === Supabase Configuration ===
# Create a project at: https://supabase.com/dashboard
# Find these values in: Project Settings > API

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key (NEVER expose this in browser!)
# Only use this in server-side code
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Project reference (optional - for CLI tools)
SUPABASE_PROJECT_REF=your_project_ref_here

# Access token (optional - for CLI tools)
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here

# === Storage Configuration ===
# Storage bucket name for documents (create this in Supabase Dashboard)
SUPABASE_BUCKET_DOCUMENTS=documents

# === API Key Encryption ===
# Used to encrypt user API keys at rest (AES-256-GCM)
# Generate with: openssl rand -hex 32
API_KEYS_ENCRYPTION_KEY=your_64_char_hex_key_here

# === Application Configuration ===
NEXT_PUBLIC_APP_NAME=CogniLeap
NEXT_PUBLIC_THEME_ACCENT=teal

# === Google Cloud Vision API (for image OCR) ===
# Get at: https://console.cloud.google.com/apis/credentials
# Enable "Cloud Vision API" in your project
# 1,000 free requests/month, then $1.50/1,000
GOOGLE_CLOUD_VISION_API_KEY=

# === Feature Flags (Optional) ===
# Live chat functionality (currently disabled)
NEXT_PUBLIC_FEATURE_FLAG_LIVE_CHAT=false
NEXT_PUBLIC_FEATURE_FLAG_LIVE_CHAT_PERCENTAGE=0
